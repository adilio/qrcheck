{
  "name": "qrcheck",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:netlify": "npx netlify-cli dev",
    "prebuild": "node scripts/prebuild.mjs",
    "build": "npm run prebuild && vite build && touch dist/.nojekyll",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .ts .",
    "test": "vitest run --reporter=verbose",
    "e2e": "playwright test",
    "ci:verify": "npm run typecheck && npm run lint && npm run test && npm run e2e && npm run build"
  },
  "netlify": {
    "dev": {
      "command": "npm run dev",
      "functions": "functions",
      "publish": "dist"
    }
  },
  "overrides": {
    "serialize-javascript": "^7.0.4",
    "uuid": "^14.0.0",
    "@fastify/static": "^9.1.1",
    "qs": "^6.15.2",
    "js-yaml": ">=4.2.0",
    "@babel/core": ">=7.29.6",
    "form-data": ">=4.0.6",
    "ws": ">=8.21.0"
  },
  "devDependencies": {
    "@netlify/functions": "^2.0.0",
    "@playwright/test": "^1.40.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^8.50.0",
    "jsdom": "^23.0.0",
    "svelte": "^5.55.9",
    "typescript": "^5.2.0",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "jsqr": "^1.4.0"
  }
}
